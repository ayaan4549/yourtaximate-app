# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# PUBLIC_SITE_URL: Public site URL for reference or redirects
PUBLIC_SITE_URL=

# GOOGLE_MAPS_API_KEY: Google Maps API key for map visualizers or location queries
GOOGLE_MAPS_API_KEY=

# RESEND_API_KEY: Authentication key for Resend email dispatch services
RESEND_API_KEY=

# CRON_SECRET: Secret signature validation for scheduled serverless cron events
CRON_SECRET=

# PAYMENTS_LIVE_WEBHOOK_SECRET: Direct verification salt for live checkout webhooks
PAYMENTS_LIVE_WEBHOOK_SECRET=

# PADDLE_LIVE_API_KEY: Live environment merchant authorization credential for Paddle payments
PADDLE_LIVE_API_KEY=

# PAYMENTS_SANDBOX_WEBHOOK_SECRET: Verification salt for development/test payment webhooks
PAYMENTS_SANDBOX_WEBHOOK_SECRET=

# PADDLE_SANDBOX_API_KEY: Sandbox credential for testing Paddle subscription triggers
PADDLE_SANDBOX_API_KEY=

# LOVABLE_API_KEY: Connection secret key for Lovable operations
LOVABLE_API_KEY=

# TWILIO_PHONE_NUMBER: Twilio virtual dispatch alerting phone number
TWILIO_PHONE_NUMBER=

# TWILIO_AUTH_TOKEN: Twilio dispatch messaging pipeline authentication token
TWILIO_AUTH_TOKEN=

# TWILIO_ACCOUNT_SID: Twilio account security identifier for SMS dispatch 
TWILIO_ACCOUNT_SID=

# AVIATIONSTACK_API_KEY: Flight route tracker and lookup authorization token
AVIATIONSTACK_API_KEY=

# Supabase Auth and Database connection variables
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
